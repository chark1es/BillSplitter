# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
#
# BUILD-TIME vs RUNTIME:
# - VITE_* variables are baked into the client bundle at build time
# - For production, set VITE_APP_URL to your production domain during build
# - At runtime, the server will prefer process.env over baked-in values
#
# PRODUCTION DEPLOYMENT (Dokploy/Docker):
# 1. Set these as build args AND runtime env vars in your deployment platform:
#    VITE_APP_URL=https://fairshare.spwnd.dev
#    BETTER_AUTH_URL=https://fairshare.spwnd.dev
#    APP_PUBLIC_URL=https://fairshare.spwnd.dev
#
# 2. Set JWKS in Convex (required for auth to work):
#    npx convex run auth:getLatestJwks --prod | npx convex env set JWKS --prod
#
# 3. Rebuild and redeploy your Docker container with the correct URLs
#
# ============================================================================

# Development: Use localhost
# Production: Use your actual domain (e.g., https://fairshare.spwnd.dev)
VITE_APP_URL=http://localhost:3000
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Auth URLs - MUST match VITE_APP_URL in production
BETTER_AUTH_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# Trusted origins for CORS (comma-separated, optional)
# Example: https://admin.example.com,https://app.example.com
BETTER_AUTH_TRUSTED_ORIGINS=

# Auth secret - MUST be changed in production
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Testing mode bypass (dev only, must be false in production)
TEST_AUTH_BYPASS=false

# OpenRouter (server-only; set in Convex dashboard for hosted actions if needed)
OPENROUTER_API_KEY=
RECEIPT_MODEL_ID=google/gemini-3.1-flash-lite-preview

# UploadThing (server reads UPLOADTHING_TOKEN; dashboard: uploadthing.com)
UPLOADTHING_TOKEN=

# Invite emails (Convex dashboard: ADMIN_EMAIL, RESEND_*; app URL for links)
ADMIN_EMAIL=
RESEND_API_KEY=
RESEND_FROM="FairShare <onboarding@yourdomain.com>"
APP_PUBLIC_URL=http://localhost:3000

# Docker / Dokploy (optional; compose defaults to 3000)
# PORT=3000
